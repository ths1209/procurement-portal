# 复制此文件为 .env.local，填入你的 Teable 配置
# Teable 控制台 → 个人设置 → API Token

# Teable API 地址（云端默认，自部署则改为你的域名）
VITE_TEABLE_API_BASE=https://app.teable.io

# Teable 个人 API Token（Settings → API Token → 创建）
VITE_TEABLE_TOKEN=your_teable_api_token_here

# 用户表的 Table ID（打开表格，URL 中 /table/ 后面的 ID）
VITE_TEABLE_USERS_TABLE_ID=tblXXXXXXXXXXXXXX

# 项目进度表 Table ID
VITE_TEABLE_PROJECTS_TABLE_ID=tblXXXXXXXXXXXXXX

# 百宝箱工具表 Table ID（存储文件附件，需在 Teable 新建一张空白表）
VITE_TEABLE_TOOLS_TABLE_ID=tblXXXXXXXXXXXXXX
